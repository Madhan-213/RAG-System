APP_NAME=Production RAG System
APP_ENV=development
DEBUG=false

API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_PORT=8501

CHROMA_PATH=chroma_store
UPLOAD_DIR=data/uploads
LOG_LEVEL=INFO

EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
RERANKER_MODEL_NAME=cross-encoder/ms-marco-MiniLM-L-6-v2

LLM_PROVIDER=openrouter
LLM_MODEL=openai/gpt-4o-mini
LLM_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1/chat/completions
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=3
LLM_RETRY_BACKOFF_SECONDS=1.5
OPENAI_COMPATIBLE_HEADERS_JSON=

OPENROUTER_API_KEY=your_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_PRIMARY_MODEL=openai/gpt-4o-mini
OPENROUTER_FALLBACK_MODELS=anthropic/claude-3-haiku,meta-llama/llama-3-70b-instruct
OPENROUTER_HTTP_REFERER=http://localhost:8000
OPENROUTER_APP_TITLE=Production RAG System

CHUNK_SIZE=600
CHUNK_OVERLAP=100
RETRIEVAL_TOP_K=5
HYBRID_ALPHA=0.65
MAX_UPLOAD_SIZE_MB=25
API_RATE_LIMIT=30/minute
ENABLE_RERANKING=true
ENABLE_QUERY_REWRITE=true
SEMANTIC_CACHE_TTL_SECONDS=3600
MAX_CONTEXT_CHARACTERS=12000
